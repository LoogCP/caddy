#!/bin/sh /etc/rc.common

START=90
STOP=10

USE_PROCD=1
PROG=/usr/bin/caddy

start_service() {
    procd_open_instance
    procd_set_param command $PROG run --config /etc/caddy/Caddyfile --adapter caddyfile
    procd_set_param respawn
    procd_set_param stderr 1
    procd_close_instance
}

reload_service() {
    procd_send_signal caddy
}
